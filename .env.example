# ArchiveCore - Environment Variables

# Database
DATABASE_URL="postgresql://archivecore:archivecore123@localhost:5432/archivecore?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO / S3
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="archivecore"
MINIO_SECRET_KEY="archivecore123"
MINIO_BUCKET="archivecore-files"
MINIO_USE_SSL=false

# JWT
JWT_SECRET="change-this-to-a-very-long-random-string-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-to-another-very-long-random-string"
JWT_REFRESH_EXPIRES_IN="7d"

# Encryption (PESEL, sensitive data)
ENCRYPTION_KEY="change-this-32-byte-hex-key-00000"

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN="http://localhost:5173"

# Client (Vite)
VITE_API_URL="http://localhost:3001/api/v1"
